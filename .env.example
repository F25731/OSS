LISTEN_ADDR=:8080
HOST_BIND=127.0.0.1
HOST_PORT=19481
DATABASE_URL=postgres://imagebed:imagebed@postgres:5432/imagebed?sslmode=disable
DB_MAX_CONNS=100
STORAGE_DIR=/data/image-bed/images
IMAGE_STORAGE_HOST_DIR=/opt/ai-image-bed/images
PUBLIC_BASE_URL=https://tc.zmoapi.cn
MAX_UPLOAD_MB=50
MAX_CONCURRENT_UPLOADS=32
# 0 means unlimited. Values are per minute.
UPLOAD_RATE_LIMIT_PER_KEY_PER_MINUTE=0
UPLOAD_RATE_LIMIT_PER_IP_PER_MINUTE=0
UPLOAD_LOG_QUEUE_SIZE=4096
# 100 logs every successful upload, 10 logs about 10%, 0 logs failures only.
SUCCESS_UPLOAD_LOG_SAMPLE_PERCENT=100

ADMIN_USER=Fyanxv
ADMIN_PASSWORD=Fyb2530+
SESSION_SECRET=change-this-to-a-long-random-string

# Format: key:name,key2:name2
UPLOAD_API_KEYS=change-this-upload-key:canvas

# Browser upload from another domain needs CORS.
# Use "*" only in private deployments.
CORS_ALLOW_ORIGINS=https://canvas.example.com
